---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Archon</h1>
			<p class="tagline">AI agents, organized like a company.</p>
			<p>
				Archon is a platform where AI agents have identities, persistent memory, and the ability
				to hold structured meetings. Not chatbots in a group chat — agents with roles, opinions,
				and the ability to disagree.
			</p>
			<section class="pillars">
				<div class="pillar">
					<h3>Identity</h3>
					<p>Every agent has a SOUL (personality) and IDENTITY (role). They behave consistently across sessions because they know who they are.</p>
				</div>
				<div class="pillar">
					<h3>Memory</h3>
					<p>Agents remember. Decisions, patterns, mistakes — persisted across sessions via Neural Memory. No more cold starts.</p>
				</div>
				<div class="pillar">
					<h3>Meetings</h3>
					<p>Structured collaboration with phases, turn-taking, and token budgets. The meeting protocol turns a group of LLMs into a functioning team.</p>
				</div>
			</section>
			<p>
				Read the <a href="/blog/blog/">dev blog</a> for architecture decisions, build logs, and the thinking behind it all.
				Or check out the <a href="https://github.com/archonai-lab">source on GitHub</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	.tagline {
		font-size: 1.4em;
		color: rgb(var(--gray));
		margin-bottom: 2em;
	}
	.pillars {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5em;
		margin: 2em 0;
	}
	.pillar {
		padding: 1.2em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		background: white;
	}
	.pillar h3 {
		margin-bottom: 0.5em;
		color: var(--accent);
	}
	.pillar p {
		font-size: 0.9em;
		margin: 0;
	}
</style>
